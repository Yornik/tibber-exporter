{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":separateMultipleMajorReleases"
  ],
  "labels": [
    "renovate",
    "dependencies"
  ],
  "forkProcessing": "enabled",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "groupName": "patch updates",
      "automerge": true
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    }
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "fix",
  "ignorePaths": [
    "docker-compose/**"
  ]
}
